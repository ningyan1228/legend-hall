---
import Base from '../../layouts/Base.astro';
import Explorer from '../../components/Explorer';
import { getPeople } from '../../data/people';
const people = await getPeople();
---
<Base title="人物档案｜星耀展馆" description="浏览足球传奇、周星驰与薛之谦的人物档案。"><section class="archive-hero section-shell"><span>ARCHIVE INDEX / 001—008</span><h1>传奇人物<br/><em>档案</em></h1><p>8 位被时代记住的人。<br/>按照领域、国家与年代探索他们的故事。</p></section><section class="section-shell archive-body"><Explorer client:load people={people} base={import.meta.env.BASE_URL}/></section></Base>
