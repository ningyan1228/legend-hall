---
import Base from '../../layouts/Base.astro'; import {getPeople} from '../../data/people'; import type {Person} from '@legend/shared';
export async function getStaticPaths(){const people=await getPeople();return people.map(person=>({params:{slug:person.slug},props:{person}}))} const {person}=Astro.props as {person:Person}; const url=new URL(Astro.url.pathname,Astro.site); const jsonLd={'@context':'https://schema.org','@type':'Person',name:person.nameZh,alternateName:person.nameEn,birthDate:person.birthDate,nationality:person.nationality,description:person.summary,url};
---
<Base title={`${person.nameZh}生平、荣誉与最新消息｜星耀展馆`} description={person.summary} jsonLd={jsonLd}><section class="profile-hero"><div class={`portrait huge ${person.category}`}>{person.nameZh.slice(0,1)}</div><div><span class="eyebrow">{person.category} · {person.nationality}</span><h1>{person.nameZh}</h1><p class="en big">{person.nameEn}</p><p>{person.summary}</p></div></section><div class="profile-grid content"><article><h2>人物生平</h2><p>{person.biography}</p><h2>职业时间线</h2><ol class="timeline">{person.slug==='lionel-messi'?<><li><b>1987</b> 出生于阿根廷罗萨里奥</li><li><b>2004</b> 完成巴塞罗那一线队首秀</li><li><b>2022</b> 带领阿根廷夺得世界杯冠军</li></>:<li><b>{person.birthDate.slice(0,4)}</b> 出生，传奇旅程由此开始</li>}</ol></article><aside><h2>核心档案</h2><dl><dt>出生日期</dt><dd>{person.birthDate}</dd><dt>出生地</dt><dd>{person.birthPlace||person.nationality}</dd><dt>状态</dt><dd>{person.status}</dd></dl><h2>核心荣誉</h2><p>{person.slug==='lionel-messi'?'世界杯冠军 · 8 次金球奖 · 多次联赛与欧冠冠军':'重要行业奖项与职业成就持续整理中'}</p></aside></div></Base>
