---
import Base from '../../layouts/Base.astro'; import {getPeople} from '../../data/people'; import type {Person} from '@legend/shared';
export async function getStaticPaths(){const people=await getPeople();return people.map(person=>({params:{slug:person.slug},props:{person}}))}
const {person}=Astro.props as {person:Person}; const rawBase=import.meta.env.BASE_URL; const base=rawBase.endsWith('/')?rawBase:`${rawBase}/`; const avatarUrl=`${base}${person.avatarUrl.replace(/^\/+/, '')}`; const url=new URL(Astro.url.pathname,Astro.site); const isMessi=person.slug==='lionel-messi'; const number=isMessi?'10':String(person.nameEn.length).padStart(2,'0'); const jsonLd={'@context':'https://schema.org','@type':'Person',name:person.nameZh,alternateName:person.nameEn,birthDate:person.birthDate,nationality:person.nationality,description:person.summary,image:new URL(avatarUrl,Astro.site),url};
---
<Base title={`${person.nameZh}生平、荣誉与最新消息｜星耀展馆`} description={person.summary} image={avatarUrl} jsonLd={jsonLd}>
  <section class="person-hero"><div class="person-number">{number}</div><img src={avatarUrl} alt={`${person.nameZh}人物照片`}/><div class="person-hero-copy"><span>LEGEND ARCHIVE / {person.category}</span><h1>{person.nameEn}</h1><h2>{person.nameZh}</h2><div><b>{person.birthDate.slice(0,4)} — {person.status==='deceased'?'LEGACY':'PRESENT'}</b><b>{person.nationality} · {person.category}</b></div></div><a href="#prologue" class="scroll-note">EXPLORE THE ARCHIVE <i></i></a></section>
  <section id="prologue" class="prologue section-shell"><span>PROLOGUE / 人物序章</span><blockquote>{isMessi?'他离开罗萨里奥时只有十三岁。多年以后，他带着世界杯回到阿根廷。':person.summary}</blockquote><p>{person.biography}</p></section>
  <section class="key-numbers">{(isMessi?[['8','BALLON D’OR'],['1','WORLD CUP'],['4','CHAMPIONS LEAGUE'],['800+','CAREER GOALS']]:[['01','LEGEND ARCHIVE'],[person.birthDate.slice(0,4),'YEAR OF BIRTH'],['16','CURATED ICONS'],['24H','LIVE UPDATES']]).map(([value,label])=><div><b>{value}</b><span>{label}</span></div>)}</section>
  <section class="career-story section-shell"><div class="section-kicker">CAREER TIMELINE / 生涯时间线</div><div class="career-line">{(isMessi?[['1987','出生于罗萨里奥'],['2000','抵达巴塞罗那'],['2009','首次获得金球奖'],['2022','世界杯夺冠']]:[[person.birthDate.slice(0,4),'传奇旅程由此开始'],['2000s','走向世界舞台'],['2010s','定义自己的时代'],['PRESENT','影响仍在延续']]).map(([year,event],index)=><article><b>{year}</b><div>{index===0&&<img src={avatarUrl} alt=""/>}<span>{event}</span></div></article>)}</div></section>
  <section class="honor-showcase section-shell"><div><span>THE TROPHY ROOM</span><h2>荣誉陈列馆</h2></div><div class="honor-rail"><article><b>{isMessi?'08':'∞'}</b><h3>个人荣誉</h3><p>记录定义职业生涯的标志性时刻。</p></article><article><b>{isMessi?'01':'01'}</b><h3>时代巅峰</h3><p>{isMessi?'FIFA WORLD CUP · 2022':'LEGACY OF THE ERA'}</p></article><article><b>{isMessi?'04':'—'}</b><h3>最高舞台</h3><p>{isMessi?'UEFA CHAMPIONS LEAGUE':'ARCHIVE IN PROGRESS'}</p></article></div></section>
  <section class="profile-facts section-shell"><div><span>ARCHIVE DATA</span><h2>人物档案</h2></div><dl><dt>出生日期</dt><dd>{person.birthDate}</dd><dt>出生地</dt><dd>{person.birthPlace||person.nationality}</dd><dt>国籍</dt><dd>{person.nationality}</dd><dt>领域</dt><dd>{person.category}</dd><dt>状态</dt><dd>{person.status}</dd></dl></section>
  <section class="person-news section-shell"><span>LATEST NOTES / 最新动态</span><h2>档案仍在继续</h2><p>动态内容将在代理新闻服务接入后更新。当前页面不展示未经验证的实时新闻。</p></section>
</Base>
