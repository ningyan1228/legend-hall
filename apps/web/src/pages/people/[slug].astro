---
import Base from '../../layouts/Base.astro';
import { getPeople } from '../../data/people';
import { profiles } from '../../data/profiles';
import { getPersonDetail } from '../../data/person-detail';
import { chartSeasons, keyStatistics, sources } from '../../data/messi';
import { mediaUrl } from '../../data/media';
import type { Person } from '@legend/shared';

export async function getStaticPaths() {
  const people = await getPeople();
  return people.map((person) => ({ params: { slug: person.slug }, props: { person } }));
}

const { person } = Astro.props as { person: Person };
const profile = profiles[person.slug];
const detail = await getPersonDetail(person.slug);
const isMessi = person.slug === 'lionel-messi';
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const localAvatar = /^https?:\/\//.test(person.avatarUrl) ? person.avatarUrl : `${base}${person.avatarUrl.replace(/^\/+/, '')}`;
const avatarUrl = isMessi ? mediaUrl(`people/${person.slug}/hero`, localAvatar) : localAvatar;
const childhoodUrl = `${base}images/people/${person.slug}/childhood.png`;
const categoryLabels: Record<string, string> = { football: '足球', film: '影视', music: '音乐' };
const fallbackTimeline = profile.timeline.map(([year, title], index) => ({ id: `fallback-${index}`, year: Number(year), title, description: '' }));
const timeline = detail?.timeline?.length ? detail.timeline : fallbackTimeline;
const career = detail?.career ?? [];
const honors = detail?.honors?.length ? detail.honors : profile.honors.map(([count, title, description]) => ({ count: Number(count) || count, category: title, description }));
const maxGoal = Math.max(...chartSeasons.map((item) => item.goals));
const pageUrl = new URL(Astro.url.pathname, Astro.site);
const jsonLd = { '@context': 'https://schema.org', '@type': 'Person', name: person.nameZh, alternateName: person.nameEn, birthDate: person.birthDate, description: person.summary, image: avatarUrl, url: pageUrl };
---
<Base title={`${person.nameZh}生平、荣誉与经典时刻｜星耀展馆`} description={person.summary} image={avatarUrl} jsonLd={jsonLd}>
  <main class="archive">
    <section class="hero">
      <div class="hero-copy"><span>LEGEND ARCHIVE · 001</span><h1>{person.nameEn}</h1><h2>{person.nameZh}</h2><p>{person.summary}</p><div class="hero-meta"><b>{person.birthDate.slice(0, 4)} — PRESENT</b><b>{person.nationality} · {categoryLabels[person.category]}</b></div><a href="#prologue">进入人物档案</a></div>
      <figure><img src={avatarUrl} alt={`${person.nameZh}人物主视觉`} /><figcaption>THE STORY BEHIND NUMBER 10</figcaption></figure>
    </section>

    <section id="prologue" class="prologue shell"><span class="kicker">PROLOGUE / 人物序章</span><blockquote>{profile.quote}</blockquote><p>{person.biography}</p></section>

    {isMessi && <section class="stats-wall">
      {keyStatistics.map((stat) => <article><b>{stat.value}</b><h3>{stat.label}</h3><p>{stat.unit}</p><small>{stat.source} · 更新 {stat.updatedAt}</small></article>)}
    </section>}

    <section class="timeline shell"><span class="kicker">CAREER TIMELINE / 生涯时间线</span>
      <div>{timeline.map((event: any, index: number) => <article><b>{event.year}</b><figure>{index === 0 && <img src={event.imageUrl || childhoodUrl} alt={`${person.nameZh}早年照片`} />}</figure><section><small>{event.eventType || 'ARCHIVE EVENT'}</small><h3>{event.title}</h3><p>{event.description}</p>{event.relatedUrl && <a href={event.relatedUrl} target="_blank" rel="noreferrer">来源 ↗</a>}</section></article>)}</div>
    </section>

    {isMessi && <>
      <section class="career shell"><span class="kicker">CLUB & COUNTRY / 俱乐部与国家队</span><div>{(career.length ? career : [
        { organization: 'FC Barcelona', startDate: '2004', endDate: '2021', description: '从拉玛西亚到队史代表人物。' },
        { organization: 'Paris Saint-Germain', startDate: '2021', endDate: '2023', description: '职业生涯的法甲篇章。' },
        { organization: 'Inter Miami CF', startDate: '2023', description: '在北美开启新的足球阶段。' },
        { organization: 'Argentina', startDate: '2005', description: '国家队队长与世界杯冠军。' },
      ]).map((item: any) => <article><small>{String(item.startDate).slice(0, 4)} — {item.endDate ? String(item.endDate).slice(0, 4) : 'PRESENT'}</small><h3>{item.organization}</h3><p>{item.description}</p>{item.appearances && <b>{item.appearances} 场 · {item.goals} 球</b>}</article>)}</div></section>

      <section class="charts shell"><span class="kicker">DATA EXHIBITION / 数据展区</span><div class="chart-grid">
        <article><h3>赛季进球走势</h3><div class="bars">{chartSeasons.map((item) => <div><i style={`height:${item.goals / maxGoal * 100}%`}></i><span>{item.season}</span><b>{item.goals}</b></div>)}</div><small>示例统计口径：俱乐部全部赛事</small></article>
        <article><h3>进球与助攻对照</h3>{chartSeasons.slice(2, 7).map((item) => <div class="comparison"><span>{item.season}</span><i style={`--goal:${item.goals}%;--assist:${item.assists}%`}></i><b>{item.goals} / {item.assists}</b></div>)}<small>金色：进球 · 灰色：助攻（演示数据）</small></article>
        <article><h3>生涯版图</h3><div class="rings"><div><b>17</b><span>巴塞罗那赛季</span></div><div><b>4</b><span>职业组织</span></div><div><b>3</b><span>洲际舞台</span></div></div><small>用于展示结构，持续由 Notion 更新</small></article>
      </div></section>
    </>}

    <section class="honors shell"><span class="kicker">THE TROPHY ROOM / 荣誉陈列</span><div>{honors.map((honor: any) => <article><b>{String(honor.count).padStart(2, '0')}</b><h3>{honor.category}</h3><p>{honor.description}</p><small>{honor.organization} {honor.year}</small></article>)}</div></section>

    <section class="moment shell"><span class="kicker">DEFINING MOMENT / 经典事件</span><blockquote>{profile.classicMoment}</blockquote></section>

    {isMessi && <section class="news-sources shell"><div><span class="kicker">LATEST / 最新动态</span><article><small>演示内容 · 等待 News 数据源接入</small><h3>梅西数字档案持续更新</h3><p>新闻模块当前只展示明确标注的演示内容，不会伪装成实时新闻。</p></article></div><div><span class="kicker">SOURCES / 资料来源</span><ol>{sources.map((source) => <li><a href={source.url} target="_blank" rel="noreferrer">{source.label} ↗</a></li>)}</ol></div></section>}

    <section class="archive-footer shell"><button id="favorite" data-slug={person.slug}>♡ 收藏人物</button><a href={`${base}people/`}>浏览全部人物 →</a></section>
  </main>
  <script is:inline>
    const button = document.querySelector('#favorite');
    if (button) {
      const key = `legend-favorite-${button.dataset.slug}`;
      const paint = () => button.textContent = localStorage.getItem(key) ? '♥ 已收藏' : '♡ 收藏人物';
      paint();
      button.addEventListener('click', () => { localStorage.getItem(key) ? localStorage.removeItem(key) : localStorage.setItem(key, '1'); paint(); });
    }
  </script>
</Base>

<style>
  .archive{background:#070b0a;color:#e9e7df}.shell{padding:110px max(6vw,32px)}.kicker{color:#c7a45a;font:700 12px/1.4 var(--sans);letter-spacing:.28em}.hero{min-height:calc(100vh - 96px);display:grid;grid-template-columns:42% 58%;border-bottom:1px solid #29302d}.hero-copy{padding:10vh 7vw;display:flex;flex-direction:column;justify-content:center;background:radial-gradient(circle at 70% 45%,#18201e 0,transparent 48%)}.hero-copy>span{color:#c7a45a;letter-spacing:.28em}.hero h1{margin:40px 0 0;font:500 clamp(70px,9vw,150px)/.75 var(--serif);text-transform:uppercase}.hero h2{font:500 clamp(28px,3vw,48px)/1.2 var(--serif);letter-spacing:.18em}.hero-copy p{max-width:560px;color:#aeb5b1;line-height:1.9}.hero-meta{display:flex;gap:38px;margin:20px 0 42px;font-size:12px;letter-spacing:.12em}.hero-copy>a{width:max-content;border:1px solid #d9d7cf;padding:18px 28px;color:inherit;text-decoration:none}.hero figure{position:relative;margin:0;overflow:hidden;background:#111}.hero figure:after{content:'';position:absolute;inset:0;background:linear-gradient(90deg,#070b0a 0,transparent 28%),linear-gradient(0deg,#070b0a 0,transparent 30%)}.hero img{width:100%;height:100%;object-fit:cover;object-position:center 56%;filter:saturate(.78) contrast(1.05)}.hero figcaption{position:absolute;z-index:2;bottom:30px;left:42px;letter-spacing:.25em;font-size:10px}.prologue{display:grid;grid-template-columns:1fr 2fr;gap:60px}.prologue blockquote{grid-column:2;margin:0;font:500 clamp(36px,5vw,76px)/1.35 var(--serif)}.prologue p{grid-column:2;max-width:900px;color:#aeb5b1;line-height:2}.stats-wall{display:grid;grid-template-columns:repeat(4,1fr);border-block:1px solid #29302d}.stats-wall article{min-height:300px;padding:52px;border-right:1px solid #29302d}.stats-wall b{font:500 clamp(68px,8vw,126px)/1 var(--serif);color:#c7a45a}.stats-wall h3{margin:30px 0 5px}.stats-wall p,.stats-wall small{color:#87908b}.timeline>div{margin-top:80px}.timeline article{display:grid;grid-template-columns:240px 300px 1fr;gap:55px;align-items:center;min-height:260px;border-top:1px solid #29302d}.timeline article>b{font:400 clamp(60px,7vw,120px)/1 var(--sans);color:#cbd0cd}.timeline figure{margin:0}.timeline img{width:100%;height:200px;object-fit:cover;object-position:center}.timeline h3{font:500 clamp(28px,3vw,48px)/1.2 var(--serif);margin:10px 0}.timeline p{color:#9ca49f}.timeline a{color:#c7a45a}.career>div,.honors>div{display:grid;grid-template-columns:repeat(4,1fr);margin-top:70px;border:1px solid #29302d}.career article,.honors article{min-height:250px;padding:36px;border-right:1px solid #29302d}.career h3,.honors h3{font:500 30px var(--serif)}.career p,.honors p{color:#9ca49f;line-height:1.8}.honors article>b{font:500 64px var(--serif);color:#c7a45a}.chart-grid{display:grid;grid-template-columns:1.5fr 1fr 1fr;gap:1px;margin-top:70px;background:#29302d}.chart-grid>article{min-height:430px;padding:34px;background:#0b100e}.bars{height:280px;display:flex;align-items:end;gap:12px;margin-top:30px}.bars div{height:100%;flex:1;display:flex;flex-direction:column;justify-content:end;align-items:center;gap:7px}.bars i{width:100%;background:#c7a45a}.bars span,.bars b,.charts small{font-size:10px;color:#9ca49f}.comparison{display:grid;grid-template-columns:50px 1fr 55px;gap:10px;align-items:center;margin:30px 0;font-size:11px}.comparison i{height:9px;background:linear-gradient(90deg,#c7a45a 0 var(--goal),#68716c var(--goal) calc(var(--goal) + var(--assist)),#18201e 0)}.rings{display:grid;gap:20px;margin-top:35px}.rings div{border:1px solid #39413d;padding:20px}.rings b{font:500 42px var(--serif);color:#c7a45a}.rings span{margin-left:16px;color:#9ca49f}.moment{border-block:1px solid #29302d}.moment blockquote{max-width:1180px;margin:55px 0 0;font:500 clamp(34px,5vw,72px)/1.45 var(--serif)}.news-sources{display:grid;grid-template-columns:1fr 1fr;gap:100px}.news-sources article{margin-top:40px;border-top:1px solid #29302d;padding-top:30px}.news-sources small{color:#c7a45a}.news-sources p,.news-sources li{color:#9ca49f;line-height:1.9}.news-sources a{color:#cbd0cd}.archive-footer{display:flex;justify-content:space-between;border-top:1px solid #29302d}.archive-footer button,.archive-footer a{background:none;border:1px solid #69716d;color:#e9e7df;padding:16px 24px;text-decoration:none}
  @media(max-width:900px){.hero{grid-template-columns:1fr}.hero-copy{min-height:70vh}.hero figure{height:70vh}.stats-wall{grid-template-columns:repeat(2,1fr)}.timeline article{grid-template-columns:1fr}.timeline figure{max-width:420px}.career>div,.honors>div,.chart-grid{grid-template-columns:1fr 1fr}.prologue{grid-template-columns:1fr}.prologue blockquote,.prologue p{grid-column:1}.news-sources{grid-template-columns:1fr}}
  @media(max-width:560px){.shell{padding:78px 22px}.hero-meta{flex-direction:column;gap:8px}.stats-wall,.career>div,.honors>div,.chart-grid{grid-template-columns:1fr}.stats-wall article{min-height:230px}.hero figure{height:60vh}.archive-footer{gap:14px;flex-direction:column}}
</style>
